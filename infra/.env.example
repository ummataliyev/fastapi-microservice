# Application
APP_NAME=Template Service
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO
SENTRY_DSN=

# CORS — JSON array of allowed origins; use ["*"] for permissive dev only.
CORS_ALLOW_ORIGINS=["*"]

# Database
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=template_service_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Docs basic auth
DOCS_USERNAME=admin
DOCS_PASSWORD=admin

# Migrations
RUN_MIGRATIONS_ON_START=true

# Permission service (external)
PERMISSION_SERVICE_URL=
PERMISSION_SERVICE_TOKEN=

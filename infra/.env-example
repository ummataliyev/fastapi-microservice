# Application
APP_NAME=FastAPI Microservice
APP_VERSION=0.1.0
APP_ENV=development
DB_PROVIDER=postgres
API_PREFIX=/api/v1
DEBUG=true
TRACING_ENABLED=true
DOCS_ENABLED=true
REDOC_ENABLED=true
OPENAPI_ENABLED=true
RUN_MIGRATIONS_ON_START=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,service-api,service-nginx
SLOW_REQUEST_THRESHOLD_MS=1000

# Database
POSTGRES_DB=micro-service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=service-db
POSTGRES_PORT=5432
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600
POSTGRES_POOL_PRE_PING=true
POSTGRES_READONLY_POOL_SIZE=5
POSTGRES_READONLY_MAX_OVERFLOW=0
POSTGRES_READONLY_POOL_TIMEOUT=30
POSTGRES_READONLY_POOL_RECYCLE=3600
POSTGRES_READONLY_POOL_PRE_PING=true

# MySQL (optional provider)
MYSQL_DB=micro-service
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_HOST=service-mysql
MYSQL_PORT=3306
MYSQL_POOL_SIZE=20
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_TIMEOUT=30
MYSQL_POOL_RECYCLE=3600
MYSQL_POOL_PRE_PING=true
MYSQL_READONLY_POOL_SIZE=5
MYSQL_READONLY_MAX_OVERFLOW=0
MYSQL_READONLY_POOL_TIMEOUT=30
MYSQL_READONLY_POOL_RECYCLE=3600
MYSQL_READONLY_POOL_PRE_PING=true

# MongoDB (optional provider)
MONGO_HOST=service-mongo
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=micro-service

# JWT settings
JWT_SECRET_KEY=your_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Auth security
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900

# Gunicorn runtime tuning
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_LIMIT_GET=10
RATE_LIMIT_LIMIT_PPD=5
RATE_LIMIT_TIME_GET=60
RATE_LIMIT_TIME_PPD=60
RATE_LIMIT_RATE_LIMIT_ENABLED=false

# Redis
REDIS_HOST=service-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SOCKET_CONNECT_TIMEOUT=2.0
REDIS_SOCKET_TIMEOUT=2.0
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_RETRY_ON_TIMEOUT=true

# HTTP settings
HTTP_CLIENT_TIMEOUT=10.0
HTTP_CLIENT_CONNECT_TIMEOUT=2.0
HTTP_CLIENT_RETRIES=2
HTTP_CLIENT_POOL_CONNECTIONS=10
HTTP_CLIENT_POOL_MAXSIZE=20

# Pagination
MAX_ENTITIES_PER_PAGE=100
